# Copy this file to .env and fill in only the values you use.
# HackWriter loads .env automatically at startup.

ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# Preferred HackMD token for HackWriter.
HACKMD_API_TOKEN=

# Optional HackMD CLI-compatible fallback token.
HMD_API_ACCESS_TOKEN=

# Optional HackMD endpoint overrides.
HACKMD_API_URL=https://api.hackmd.io/v1
HMD_API_ENDPOINT_URL=https://api.hackmd.io/v1
HACKMD_MCP_URL=https://mcp.hackmd.io
